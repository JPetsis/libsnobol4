{
  "name": "libsnobol4/libsnobol4",
  "description": "SNOBOL4 pattern matching library — monorepo root",
  "type": "project",
  "license": "Apache-2.0",
  "keywords": ["snobol", "pattern-matching", "string-processing"],
  "require": {
    "php": ">=8.3",
    "ext-ctype": "*",
    "ext-mbstring": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5"
  },
  "autoload": {
    "psr-4": {
      "Snobol\\": "bindings/php/php-src/"
    },
    "files": [
      "bindings/php/php-src/functions.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "Snobol\\Tests\\": "bindings/php/tests/php/"
    }
  }
}

