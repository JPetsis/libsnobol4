#pragma once

/**
 * @file version.h
 * @brief libsnobol4 version macros (generated by CMake)
 *
 * This file is generated from version.h.in by CMake's configure_file()
 * at configure time.  The single source of truth for the library version
 * is the `project(libsnobol4 VERSION X.Y.Z)` declaration in the top-level
 * CMakeLists.txt.  Do NOT edit version literals here by hand — bump the
 * version in CMake and reconfigure.
 */

#ifdef __cplusplus
extern "C" {
#endif

/** @brief Library major version number. */
#define SNOBOL_VERSION_MAJOR @SNOBOL_VERSION_MAJOR@

/** @brief Library minor version number. */
#define SNOBOL_VERSION_MINOR @SNOBOL_VERSION_MINOR@

/** @brief Library patch version number. */
#define SNOBOL_VERSION_PATCH @SNOBOL_VERSION_PATCH@

/** @brief Library version as a string literal, e.g. @c "0.12.0". */
#define SNOBOL_VERSION_STRING "@SNOBOL_VERSION_STRING@"

#ifdef __cplusplus
}
#endif
