{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 16,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "debug",
      "displayName": "Debug",
      "description": "Debug build with tests enabled",
      "binaryDir": "${sourceDir}/build-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "BUILD_TESTS": "ON",
        "BUILD_PHP": "OFF",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "release",
      "displayName": "Release",
      "description": "Optimised release build",
      "binaryDir": "${sourceDir}/build-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "BUILD_TESTS": "ON",
        "BUILD_PHP": "OFF",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "asan",
      "displayName": "AddressSanitizer + UBSan",
      "description": "Debug build with AddressSanitizer and UndefinedBehaviorSanitizer enabled",
      "binaryDir": "${sourceDir}/build-asan",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "BUILD_TESTS": "ON",
        "BUILD_PHP": "OFF",
        "SNOBOL_SANITIZE": "ON",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "windows-msvc",
      "displayName": "Windows (MSVC)",
      "description": "Windows build with Visual Studio 2022",
      "generator": "Visual Studio 17 2022",
      "binaryDir": "${sourceDir}/build-msvc",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "BUILD_TESTS": "ON",
        "BUILD_PHP": "OFF"
      }
    },
    {
      "name": "windows-mingw",
      "displayName": "Windows (MinGW-w64)",
      "description": "Windows build with MinGW-w64",
      "generator": "MinGW Makefiles",
      "binaryDir": "${sourceDir}/build-mingw",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "BUILD_TESTS": "ON",
        "BUILD_PHP": "OFF"
      }
    },
    {
      "name": "pgo-gen",
      "displayName": "PGO Instrumentation",
      "description": "Release build with PGO instrumentation (-fprofile-generate). Train with snobol4_probe, merge to build-pgo/profdata, then build pgo-use.",
      "binaryDir": "${sourceDir}/build-pgo-gen",
      "inherits": "release",
      "cacheVariables": {
        "BUILD_BENCH_C": "ON",
        "SNOBOL_PGO_GEN": "ON"
      }
    },
    {
      "name": "pgo-use",
      "displayName": "PGO Optimized",
      "description": "Release build using PGO profile data (requires build-pgo/profdata produced by pgo-train).",
      "binaryDir": "${sourceDir}/build-pgo-use",
      "inherits": "release",
      "cacheVariables": {
        "SNOBOL_PGO_USE": "ON",
        "SNOBOL_PGO_PROFILE": "${sourceDir}/build-pgo/profdata"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "debug",
      "configurePreset": "debug"
    },
    {
      "name": "release",
      "configurePreset": "release"
    },
    {
      "name": "asan",
      "configurePreset": "asan"
    },
    {
      "name": "pgo-gen",
      "configurePreset": "pgo-gen"
    },
    {
      "name": "pgo-use",
      "configurePreset": "pgo-use"
    }
  ],
  "testPresets": [
    {
      "name": "debug",
      "configurePreset": "debug",
      "output": { "outputOnFailure": true }
    },
    {
      "name": "release",
      "configurePreset": "release",
      "output": { "outputOnFailure": true }
    },
    {
      "name": "asan",
      "configurePreset": "asan",
      "output": { "outputOnFailure": true }
    },
    {
      "name": "pgo-gen",
      "configurePreset": "pgo-gen",
      "output": { "outputOnFailure": true }
    },
    {
      "name": "pgo-use",
      "configurePreset": "pgo-use",
      "output": { "outputOnFailure": true }
    }
  ]
}

