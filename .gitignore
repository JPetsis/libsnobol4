# Build artifacts and generated files
*.so
*.o
*.lo
*.la

# IDE files (PhpStorm)
.idea/
*.iml

# CMake build directories
build/
build_test/

# OS files
.DS_Store
Thumbs.db

# Logs and temp files
*.log
*.tmp
*.swp
*.bak

# Vendor and dependencies (if using Composer)
vendor/
composer.lock

# Downloaded UCD data (regenerated by make gen-unicode-fold)
CaseFolding.txt

# Generated version header (single source: top-level CMakeLists.txt VERSION;
# produced by CMake configure_file for the C build and by
# dev/generate_version_header.sh for the PHP amalgam build)
core/include/snobol/version.h

# Other common exclusions
.env
node_modules/
